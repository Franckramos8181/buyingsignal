# ---------------------------------------------------------------------------
# buyingsignal — example environment. Copy to .env (local) or
# /etc/buyingsignal/secrets.env (droplet, chmod 600). DO NOT COMMIT REAL VALUES.
# ---------------------------------------------------------------------------

# --- LLM (Groq by default; provider-abstracted, see scoring/llm.py) ----------
# Provider one of: groq | deepinfra | openai-compatible
LLM_PROVIDER=groq
GROQ_API_KEY=
# Model id for the chosen provider. Groq high-volume classifier default below.
LLM_MODEL=llama-3.3-70b-versatile
# Optional: override base URL for an OpenAI-compatible provider (e.g. DeepInfra
# for a Hermes model: https://api.deepinfra.com/v1/openai)
LLM_BASE_URL=
# DeepInfra / OpenRouter / Together key when LLM_PROVIDER != groq
LLM_API_KEY=

# --- Datastores --------------------------------------------------------------
# Async SQLAlchemy URL. Local dev compose default below; use managed PG in prod.
DATABASE_URL=postgresql+asyncpg://buyingsignal:buyingsignal@localhost:5432/buyingsignal
REDIS_URL=redis://localhost:6379/0

# --- Slack -------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# --- Collectors --------------------------------------------------------------
# SEC requires a descriptive User-Agent with contact info on every request.
EDGAR_USER_AGENT=buyingsignal/0.1 (ops@example.com)
# Comma-separated RSS/Atom feed URLs to poll.
RSS_FEEDS=https://www.prnewswire.com/rss/news-releases-list.rss
# JSON describing generic permitted REST sources (see config.py RestSource).
# Example: [{"name":"example","url":"https://api.example.com/events","items_path":"data","uid_field":"id","title_field":"title","url_field":"link"}]
REST_SOURCES=[]

# Poll intervals (seconds) for cron-driven collectors.
EDGAR_INTERVAL_SECONDS=900
RSS_INTERVAL_SECONDS=600
REST_INTERVAL_SECONDS=900

# --- Scoring / routing -------------------------------------------------------
# Minimum relevance (0-100) required to notify Slack.
SCORE_THRESHOLD=60

# --- Ops ---------------------------------------------------------------------
LOG_LEVEL=INFO
# Set to "1" to log scored payloads (never logs secrets regardless).
DEBUG_LOG_PAYLOADS=0
